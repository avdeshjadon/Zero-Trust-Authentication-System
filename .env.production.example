# ==========================================
# Application Configuration (PRODUCTION)
# ==========================================
APP_NAME=ZeroTrustAuth
APP_ENV=production
APP_PORT=8080
APP_BASE_URL=https://api.yourdomain.com
API_BASE_PATH=/

# ==========================================
# Database Configuration (MySQL)
# ==========================================
# Set DB_HOST to your managed database service (e.g., AWS RDS, GCP Cloud SQL)
DB_HOST=your-production-db.example.com
DB_PORT=3306
DB_NAME=zerotrust_prod
DB_USERNAME=your_secure_db_user
# Use a strong, generated password
DB_PASSWORD=your_secure_db_password
DB_URL=jdbc:mysql://${DB_HOST}:${DB_PORT}/${DB_NAME}?useSSL=true&serverTimezone=UTC

# ==========================================
# Redis Configuration
# ==========================================
# Set REDIS_HOST to your managed Redis service (e.g., AWS ElastiCache)
REDIS_HOST=your-production-redis.example.com
REDIS_PORT=6379
# Use a strong, generated password
REDIS_PASSWORD=your_secure_redis_password
REDIS_DATABASE=0
REDIS_SSL_ENABLED=true

# ==========================================
# JWT Configuration
# ==========================================
# CRITICAL: Generate a strong random 256-bit or 512-bit key. Do NOT use default or guessable values.
# Example generation: openssl rand -base64 64
JWT_SECRET=avdeshkumarpalsumanjadon
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000 # 15 minutes
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000 # 7 days
JWT_ISSUER=ZeroTrustAuthProd

# ==========================================
# CORS Configuration
# ==========================================
# Only allow specific production domains
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=authorization,content-type,x-auth-token
CORS_ALLOW_CREDENTIALS=true

# ==========================================
# Security Configuration
# ==========================================
BCRYPT_STRENGTH=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_DURATION_MINUTES=30
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION_SECONDS=60

# ==========================================
# Token Configuration
# ==========================================
ACCESS_TOKEN_BLACKLIST_PREFIX=jwt:blacklist:
REFRESH_TOKEN_HASH_ALGORITHM=SHA-256

# ==========================================
# Swagger/OpenAPI Configuration
# ==========================================
# Disable Swagger in production for security
SWAGGER_ENABLED=false
SWAGGER_SERVER_URL=https://api.yourdomain.com

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_APP=INFO
LOG_FILE_PATH=/var/log/zerotrust/app.log

# ==========================================
# Docker Initialization Environment Variables
# ==========================================
MYSQL_ROOT_PASSWORD=generate_strong_root_password
MYSQL_DATABASE=zerotrust_prod
MYSQL_USER=your_secure_db_user
MYSQL_PASSWORD=your_secure_db_password

# Port mappings for Docker (Host:Container)
APP_PORT_MAPPING=8080
DB_PORT_MAPPING=3306
REDIS_PORT_MAPPING=6379
