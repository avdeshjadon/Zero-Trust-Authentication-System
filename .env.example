# ==========================================
# Application Configuration
# ==========================================
APP_NAME=ZeroTrustAuth
APP_ENV=local
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
API_BASE_PATH=/

# ==========================================
# Database Configuration (MySQL)
# ==========================================
# Host inside docker network is 'mysql'. If running app locally without docker, use 'localhost'.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zerotrust_db
DB_USERNAME=dbuser
DB_PASSWORD=dbpassword
DB_URL=jdbc:mysql://${DB_HOST}:${DB_PORT}/${DB_NAME}?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true

# ==========================================
# Redis Configuration
# ==========================================
# Host inside docker network is 'redis'. If running app locally without docker, use 'localhost'.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword
REDIS_DATABASE=0
REDIS_SSL_ENABLED=false

# ==========================================
# JWT Configuration
# ==========================================
# Use a strong 256-bit (at least 32 chars) secret key for JWT signing.
JWT_SECRET=super_secret_key_for_local_development_only_do_not_use_in_prod
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000 # 15 minutes
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000 # 7 days
JWT_ISSUER=ZeroTrustAuth

# ==========================================
# CORS Configuration
# ==========================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=authorization,content-type,x-auth-token
CORS_ALLOW_CREDENTIALS=true

# ==========================================
# Security Configuration
# ==========================================
BCRYPT_STRENGTH=10
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_DURATION_MINUTES=15
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION_SECONDS=60

# ==========================================
# Token Configuration
# ==========================================
ACCESS_TOKEN_BLACKLIST_PREFIX=jwt:blacklist:
REFRESH_TOKEN_HASH_ALGORITHM=SHA-256

# ==========================================
# Swagger/OpenAPI Configuration
# ==========================================
SWAGGER_ENABLED=true
SWAGGER_SERVER_URL=http://localhost:8080

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_FILE_PATH=logs/app.log

# ==========================================
# Docker Initialization Environment Variables
# These variables are specifically used by the database containers to initialize themselves.
# ==========================================
MYSQL_ROOT_PASSWORD=rootsecret
MYSQL_DATABASE=zerotrust_db
MYSQL_USER=dbuser
MYSQL_PASSWORD=dbpassword

# Port mappings for Docker (Host:Container)
APP_PORT_MAPPING=8080
DB_PORT_MAPPING=3306
REDIS_PORT_MAPPING=6379
